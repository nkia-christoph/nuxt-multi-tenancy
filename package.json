{
  "name": "nuxt-multi-tenancy",
  "version": "2.0.0",
  "description": "Multi-domain tenancy for Nuxt — per-domain layouts, translation overrides, and metadata with SSR/SPA/prerender support",
  "repository": "hieuhani/nuxt-multi-tenancy",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "nuxt-module-build build",
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:generate": "nuxi generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "build": "bun run dev:prepare && bun run dev:build",
    "release": "bun run prepack && changelogen --release --no-commit --no-tag && npm publish",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "workspaces": [
    "playground"
  ],
  "dependencies": {
    "@nuxt/kit": "^3.16.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^3.16.0",
    "@nuxt/test-utils": "^3.17.0",
    "@types/node": "^22.0.0",
    "changelogen": "^0.5.7",
    "nuxt": "^3.16.0",
    "vitest": "^3.0.0"
  }
}
